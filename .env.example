# ---- App ----
APP_NAME="Krayin CRM"
APP_ENV=production
APP_DEBUG=false
APP_URL=https://your-app.up.railway.app
APP_TIMEZONE=UTC
APP_LOCALE=en

# ---- Database (from Railway MySQL add-on) ----
DB_CONNECTION=mysql
DB_HOST=${MYSQLHOST}
DB_PORT=${MYSQLPORT}
DB_DATABASE=${MYSQLDATABASE}
DB_USERNAME=${MYSQLUSER}
DB_PASSWORD=${MYSQLPASSWORD}

# ---- Cache / Session / Queue ----
CACHE_DRIVER=file
SESSION_DRIVER=file
QUEUE_CONNECTION=sync

# ---- Mail (optional - configure later) ----
MAIL_MAILER=smtp
MAIL_HOST=smtp.mailgun.org
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=crm@yourdomain.com
MAIL_FROM_NAME="Krayin CRM"
